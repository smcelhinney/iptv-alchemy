# ---------------------------------------------------------------------------
# Xtream Codes API credentials (required)
#
# Seed values: read from here on first startup and stored in Redis via SETNX.
# After that, manage via Admin → Configuration in the UI.
# ---------------------------------------------------------------------------
XTREAM_SERVER_URL=http://your-provider.example.com
XTREAM_USERNAME=your_username
XTREAM_PASSWORD=your_password

# ---------------------------------------------------------------------------
# Meilisearch (full-text search backend)
#
# A single key used for both the Meilisearch master key and the API client.
# The default is enough to get started locally. For anything beyond dev,
# generate a strong random key (>= 16 bytes) and set it here.
# ---------------------------------------------------------------------------
MEILISEARCH_KEY=iptv-alchemy-default-key

# ---------------------------------------------------------------------------
# Redis (configuration cache + category store)
#
# Overridden by docker-compose to redis://iptv-redis:6379/0 inside the stack.
# Only set REDIS_URL if you're running the processor locally outside Docker.
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6380/0

# ---------------------------------------------------------------------------
# Optional integrations
#
# All values below are seed-only: read from .env on first startup (SETNX into
# Redis), then managed via Admin → Configuration. Commented out = not set.
# ---------------------------------------------------------------------------

# TMDB metadata enrichment (https://www.themoviedb.org/settings/api)
# TMDB_API_KEY=

# Emby media server
# EMBY_SERVER=http://your-emby-server:8096
# EMBY_API_KEY=

# Jellyfin media server
# JELLYFIN_SERVER=http://your-jellyfin-server:8096
# JELLYFIN_API_KEY=

# OpenSubtitles
# OPEN_SUBTITLES_API_KEY=
# OPEN_SUBTITLES_USERNAME=
# OPEN_SUBTITLES_PASSWORD=

# ---------------------------------------------------------------------------
# Docker host-mount directories
#
# Override to point at your existing media library so .strm files land where
# Emby/Jellyfin can pick them up. Defaults to ./media/... inside the container.
# ---------------------------------------------------------------------------
MOVIES_DIR=./media/movies
TV_DIR=./media/tv
PRIVATE_DIR=./media/private

# ---------------------------------------------------------------------------
# Docker compose tuning (all have sensible defaults — only set to override)
# ---------------------------------------------------------------------------

# Meilisearch
# MEILI_ENV=development
# MEILISEARCH_PORT=7700

# Redis
# REDIS_PORT=6380

# ---------------------------------------------------------------------------
# Reverse proxy network
#
# External Docker network your reverse proxy (Caddy/Traefik/Nginx) lives on.
# The API and UI containers join this so the proxy can route to them.
# Create it before starting the stack:
#   docker network create proxy
# ---------------------------------------------------------------------------
PROXY_NETWORK=proxy
